# YesCaptcha API key
YESCAPTCHA_KEY="your_key_here"

# DuckMail 邮箱服务配置（API: https://duckmail.sbs）
# 注册后在 https://duckmail.sbs 获取 bearer token
DUCKMAIL_BEARER="your_duckmail_bearer_here"
# 可选: 自定义 API 地址（默认: https://api.duckmail.sbs）
# DUCKMAIL_API_BASE="https://api.duckmail.sbs"

# 可选代理示例
# HTTP_PROXY="http://127.0.0.1:7890"
# HTTPS_PROXY="http://127.0.0.1:7890"
